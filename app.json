{
  "expo": {
    "name": "TAKAM",
    "slug": "takam",
    "version": "1.0.0",
    "scheme": "takam",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5ECD7"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.takam.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Used for gift delivery address.",
        "NFCReaderUsageDescription": "Tap-to-Bond uses NFC to securely connect you with your partner."
      },
      "entitlements": {
        "com.apple.developer.nfc.readersession.formats": [
          "NDEF",
          "TAG"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5ECD7"
      },
      "package": "com.takam.app",
      "intentFilters": [
        {
          "action": "android.nfc.action.NDEF_DISCOVERED",
          "data": [
            {
              "protocol": "https",
              "host": "takam.app"
            }
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "notification": {
        "vapidPublicKey": "PLACEHOLDER_VAPID_KEY"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.YOUR_IOS_CLIENT_ID"
        }
      ],
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "Allow TAKAM to interact with nearby NFC devices.",
          "includeNdefEntitlement": true
        }
      ],
      "expo-audio"
    ],
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
